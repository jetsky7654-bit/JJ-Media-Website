# Vercel/Neon/Supabase stellen normalerweise DATABASE_URL bereit.
# DATABASE_URI und POSTGRES_URL werden ebenfalls akzeptiert.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
PAYLOAD_SECRET=replace-with-at-least-32-random-characters
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
REVALIDATION_SECRET=replace-with-another-random-secret
NEXT_PUBLIC_CONTACT_EMAIL=service@jj-media.info
